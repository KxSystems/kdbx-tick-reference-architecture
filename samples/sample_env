# Shared configuration for the tick and tick-x reference stacks.
#
# Sourced by every startup.sh / restart.sh under tick/scripts and tick-x/scripts,
# so a value changed here applies to BOTH levels. The tick-x-only settings (IDB,
# chained RDB, flush interval) are simply ignored by the base tick scripts.
#
# To customize without touching the committed defaults, copy this file (e.g. to
# .env) and pass it with -e:  ./tick-x/scripts/startup.sh -e .env
#
# Paths are derived from ROOT_DIR. ROOT_DIR defaults to the directory the script
# was launched from (the project root), so absolute paths hold even after the q
# processes cd into the HDB root at connect time.
export ROOT_DIR="${ROOT_DIR:-$(pwd)}"
export SCHEMA_DIR=$ROOT_DIR/samples/schemas
export SAMPLE_DATA=$ROOT_DIR/samples/data
export TPLOG_DIR=$ROOT_DIR/app/tplogs
export TPLOG_NAME=tpLog
export HDB_DIR=$ROOT_DIR/app/hdb
export PROCESS_LOG_DIR=$ROOT_DIR/app/proclogs
export LOG_LEVEL=info

# Process ports
export TICK_PORT=5010
export RDB_PORT=5011             # tick-x: main RDB (writedown role)
export HDB_PORT=5012
export GW_PORT=5013
export FH_PORT=5014
export IDB_PORT=5015
export RTE_PORT=5016
export CHAINED_RDB_PORT=5017     # tick-x: chained RDB (query role)

# Intraday writedown (tick-x): the main RDB flushes int-partitions into IDB_DIR
# every FLUSH_INTV_MIN minutes; the IDB serves them on the `idb` query tier.
export IDB_DIR=$ROOT_DIR/app/idb
export FLUSH_INTV_MIN=5

# Feedhandler
export FH_TIMER=60000
export FH_ANALYTIC_DIR=$ROOT_DIR/samples/data/fh-analytics

# Gateway
export ANALYTIC_DIR=$ROOT_DIR/samples/analytics

# Real-Time Engine
export RTE_ENRICH_FILE=$ROOT_DIR/samples/enrichments/enrich-sample.q
